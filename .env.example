# 环境配置文件
# 请根据实际环境修改以下配置

# 服务端口
PORT=3000

# 数据库配置
DB_HOST=localhost
DB_PORT=3306
DB_NAME=inspector_db
DB_USER=inspector
DB_PASSWORD=Inspector2025!

# JWT 密钥（生产环境请使用更复杂的密钥）
JWT_SECRET=your-secret-key-change-this-in-production-2025
JWT_EXPIRES_IN=7d

# 日志配置
LOG_LEVEL=info

# 上传配置
UPLOAD_DIR=/tmp/inspector-uploads
MAX_FILE_SIZE=10485760
